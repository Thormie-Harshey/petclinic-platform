{
  "title": "Petclinic — JVM Metrics",
  "uid": "petclinic-jvm",
  "schemaVersion": 38,
  "version": 2,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "Heap Usage % — All Services",
      "type": "gauge",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 0},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "sum by (job) (jvm_memory_used_bytes{area=\"heap\"}) / sum by (job) (jvm_memory_max_bytes{area=\"heap\"}) * 100",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 60},
              {"color": "orange", "value": 75},
              {"color": "red", "value": 90}
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "Live Thread Count — All Services",
      "type": "stat",
      "gridPos": {"h": 4, "w": 24, "x": 0, "y": 8},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{job}}"
        }
      ],
      "options": {
        "reduceOptions": {"calcs": ["lastNotNull"]},
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 100},
              {"color": "red", "value": 200}
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "Heap Used (bytes)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_memory_used_bytes{area=\"heap\"}",
          "legendFormat": "{{job}} — {{id}}"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_memory_max_bytes{area=\"heap\"}",
          "legendFormat": "{{job}} — max"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "bytes"}}
    },
    {
      "id": 4,
      "title": "GC Pause Duration (p99)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "histogram_quantile(0.99, sum by (job, le) (rate(jvm_gc_pause_seconds_bucket[5m])))",
          "legendFormat": "{{job}} GC p99"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "id": 5,
      "title": "Live vs Daemon Threads (trend)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_live_threads",
          "legendFormat": "{{job}} live"
        },
        {
          "refId": "B",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "jvm_threads_daemon_threads",
          "legendFormat": "{{job}} daemon"
        }
      ]
    },
    {
      "id": 6,
      "title": "GC Collections Rate",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {
          "refId": "A",
          "datasource": {"type": "prometheus", "uid": "prometheus"},
          "expr": "rate(jvm_gc_pause_seconds_count[5m])",
          "legendFormat": "{{job}} — {{action}} {{cause}}"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "ops"}}
    }
  ]
}
